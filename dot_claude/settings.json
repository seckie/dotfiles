{
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "security-guidance@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "emoffice-team@revcomm": true
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr checkout:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh search:*)",
      "Bash(gh auth status)",
      "Bash(gh --version)"
    ]
  },
  "sandbox": {
      "enabled": true,
      "allowUnsandboxedCommands": false,
      "excludedCommands": [
          "gh pr view*",
          "gh pr list*",
          "gh pr create*",
          "gh pr checkout*",
          "gh pr comment*",
          "gh issue view*",
          "gh issue list*",
          "gh repo view*",
          "gh search*",
          "gh auth status",
          "gh --version"
      ],
      "network": {
          "allowedDomains": [
              "github.com",
              "api.github.com"
          ]
      }
  },
  "theme": "auto"
}
